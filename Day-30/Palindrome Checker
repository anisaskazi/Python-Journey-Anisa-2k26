# Day 30: Palindrome Checker

def is_palindrome(s):
    # Remove spaces and convert to lowercase
    s = s.replace(" ", "").lower()

    # Check if string is equal to its reverse
    return s == s[::-1]


# Input from user
text = input("Enter a string: ")

# Output
if is_palindrome(text):
    print("Palindrome")
else:
    print("Not Palindrome")
