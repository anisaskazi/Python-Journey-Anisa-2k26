from PyPDF2 import PdfReader, PdfWriter

def protect_pdf(input_pdf, output_pdf, password):
    try:
        reader = PdfReader(input_pdf)
        writer = PdfWriter()

        for page in reader.pages:
            writer.add_page(page)

        writer.encrypt(password)

        with open(output_pdf, "wb") as file:
            writer.write(file)

        print(f"Protected PDF saved as: {output_pdf}")

    except FileNotFoundError:
        print("PDF file not found!")
    except Exception as e:
        print("Error:", e)


if __name__ == "__main__":
    input_pdf = input("Enter input PDF file name: ")
    output_pdf = input("Enter output PDF file name: ")
    password = input("Enter password for PDF: ")

    protect_pdf(input_pdf, output_pdf, password)
